{
  "name": "rollhook",
  "type": "module",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "e2e"
  ],
  "packageManager": "bun@1.3.9",
  "scripts": {
    "prepare": "lefthook install",
    "dev": "bun run --parallel dev:marketing dev:dashboard dev:server",
    "dev:marketing": "cd apps/marketing && bun run dev",
    "dev:dashboard": "cd apps/dashboard && bun run dev",
    "dev:server": "docker build -q -t rollhook-e2e-server:latest . && ROLLHOOK_SECRET=${ROLLHOOK_SECRET:-dev-secret} PROJECT_ROOT=$(pwd) docker compose -f e2e/compose.e2e.yml --project-name rollhook-e2e up",
    "build:dashboard": "cd apps/dashboard && bun run build",
    "typecheck": "bun run --filter '*' typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test:e2e": "bun --filter @rollhook/e2e test",
    "e2e:up": "docker compose -f e2e/compose.e2e.yml up -d",
    "e2e:down": "docker compose -f e2e/compose.e2e.yml down -v",
    "e2e:build": "docker build -t rollhook-e2e-hello:v1 --build-arg BUILD_VERSION=v1 e2e/hello-world && docker build -t rollhook-e2e-hello:v2 --build-arg BUILD_VERSION=v2 e2e/hello-world",
    "demo:export": "ROLLHOOK_SECRET=${ROLLHOOK_SECRET:-dev-secret} bun e2e/export-demo.ts",
    "generate:api": "bun run --filter @rollhook/dashboard generate:api"
  },
  "devDependencies": {
    "@antfu/eslint-config": "7.4.3",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@types/bun": "latest",
    "astro-eslint-parser": "^1.3.0",
    "eslint": "latest",
    "eslint-plugin-astro": "^1.6.0",
    "eslint-plugin-format": "^2.0.0",
    "lefthook": "^1.11.13",
    "typescript": "beta"
  }
}
